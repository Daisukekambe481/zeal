# Server
PORT=3000

# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# In Docker, HOST is the service name: "postgres"
DATABASE_URL=postgresql://postgres:yourpassword@postgres:5432/zeal

# PostgreSQL container credentials (used by the postgres service in docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=zeal

# JWT — use long random strings, NEVER the same value for both
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here